PORT=3001
NODE_ENV=development

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_64char_hex
JWT_REFRESH_SECRET=change_me_different_64char_hex

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change_me_32byte_hex

DB_PATH=./data/panel.db
LOGS_DIR=./logs

# Optional: AdGuardHome (read-only status). Leave ADGUARD_URL unset to disable.
# ADGUARD_URL=http://192.168.1.2:3000
# ADGUARD_USERNAME=admin
# ADGUARD_PASSWORD=

# Optional: Telegram (v2)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
